# 生产环境变量 — 复制到 /www/liubai/backend/.env
# cp backend/.env.example /www/liubai/backend/.env
# chmod 600 /www/liubai/backend/.env
#
# 也可直接使用 backend/.env.example 作为模板

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

HOST=127.0.0.1
PORT=8000

DATA_DIR=/www/liubai
SERVE_STATIC=false

CORS_ORIGINS=https://honkerc.cn
