# /etc/blog/env — honkerc.cn 服务器
# sudo mkdir -p /etc/blog /www/liubai/uploads
# sudo cp deploy/honkerc.cn.env.example /etc/blog/env
# sudo chmod 600 /etc/blog/env

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

HOST=127.0.0.1
PORT=8000

# 数据目录：/www/liubai/db.sqlite3 + /www/liubai/uploads/
DATA_DIR=/www/liubai

SERVE_STATIC=false

CORS_ORIGINS=https://honkerc.cn
