# 复制到 /etc/blog/env
# sudo mkdir -p /etc/blog
# sudo cp deploy/env.example /etc/blog/env
# sudo chmod 600 /etc/blog/env

# ===== 必填（生产务必修改） =====
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ===== 服务 =====
HOST=127.0.0.1
PORT=8000

# 持久化：数据库 + uploads（Nginx /uploads/ 指向 /www/blog/data/uploads）
DATA_DIR=/www/blog/data

SERVE_STATIC=false

# ===== 可选 =====
# CORS_ORIGINS=https://your-domain.com
# UPLOAD_DIR_MAX_BYTES=2147483648
