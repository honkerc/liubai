# 复制到 /www/liubai/backend/.env
# cp deploy/env.example /www/liubai/backend/.env
# chmod 600 /www/liubai/backend/.env

SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

HOST=127.0.0.1
PORT=8000

# 持久化：/www/liubai/db.sqlite3 + /www/liubai/uploads/
DATA_DIR=/www/liubai
UPLOAD_DIR=/www/liubai/uploads

SERVE_STATIC=false

# CORS_ORIGINS=https://your-domain.com
