# 复制为 .env 后修改
# 开发：cp .env.example .env
# 生产：cp .env.example /www/liubai/backend/.env && chmod 600 /www/liubai/backend/.env

# ===== 必填（生产务必修改） =====
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ===== 服务 =====
HOST=127.0.0.1
PORT=8000

# 本地开发：默认使用 backend/ 目录（db.sqlite3、uploads/）
# DATA_DIR=

# 生产（Nginx 部署）：
# DATA_DIR=/www/liubai
# SERVE_STATIC=false
# CORS_ORIGINS=https://honkerc.cn

# Docker / 本地生产验证：
# DATA_DIR=/data
# STATIC_DIR=/app/static
# SERVE_STATIC=true
# HOST=0.0.0.0

# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
