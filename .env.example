# 复制为 .env 后修改（docker compose 会自动读取）
# cp .env.example .env

# ===== 必填（生产务必修改） =====
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ===== 服务 =====
HOST=127.0.0.1
PORT=8000

# Nginx + systemd 部署见 deploy/env.example（SERVE_STATIC=false）
# Docker 部署见下方 STATIC_DIR / SERVE_STATIC
# ===== Docker 专用（Nginx 部署请用 deploy/env.example） =====
# DATA_DIR=/data
# STATIC_DIR=/app/static
# SERVE_STATIC=true
# HOST=0.0.0.0
# API_VERSION=1.0.0
# BUILD_TIME=
# DATABASE_NAME=db.sqlite3
# UPLOAD_DIR=/data/uploads
# UPLOAD_DIR_MAX_BYTES=2147483648
# CORS_ORIGINS=https://your-domain.com
